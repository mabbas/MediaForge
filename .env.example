# GrabItDown Environment Configuration
# Copy to .env and modify as needed
GID_APP__ENVIRONMENT=development
GID_APP__DEBUG=false
GID_APP__LOG_LEVEL=INFO
GID_DOWNLOAD__OUTPUT_DIRECTORY=./downloads
GID_DOWNLOAD__MAX_CONCURRENT_DOWNLOADS=3

# GrabItDown API Configuration
GID_API_HOST=0.0.0.0
GID_API_PORT=8000
GID_API_DEBUG=false

# PostgreSQL (Development)
GID_API_DATABASE_URL=postgresql+asyncpg://gid_user:gid_dev_password@localhost:5432/grabitdown
GID_API_DATABASE_SCHEMA=gid
GID_API_DATABASE_POOL_SIZE=10

# For testing with SQLite:
# GID_API_DATABASE_URL=sqlite+aiosqlite:///./data/test.db

# Rate limiting
GID_API_RATE_LIMIT_PER_MINUTE=60

# Auth (change in production!)
GID_API_SECRET_KEY=change-this-in-production

# ffmpeg/ffprobe directory for video+audio merge (optional; else uses PATH)
# .env is loaded from project root (d:\Dev\GrabItDown\.env). On Windows use
# forward slashes so backslashes are not interpreted as escapes:
# GID_FFMPEG_LOCATION=C:/ffmpeg/bin

